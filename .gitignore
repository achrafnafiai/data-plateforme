# Dossiers binaires de NiFi (lourds, inutiles en Git)
opt/nifi/content_repository/
opt/nifi/flowfile_repository/
opt/nifi/provenance_repository/
opt/nifi/database_repository/
opt/nifi/nar_repository/
opt/nifi/logs/
opt/nifi/work/
