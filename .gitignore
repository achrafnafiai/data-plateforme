# Fichiers sensibles de configuration (mots de passe, clés)
opt/nifi/conf/login-identity-providers.xml
opt/nifi/conf/authorizers.xml
opt/nifi/conf/keystore.jks
opt/nifi/conf/truststore.jks
opt/nifi/conf/nifi.properties

# Fichiers temporaires
*.tmp
*.pid
*.log
